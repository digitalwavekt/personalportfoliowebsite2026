# Server
PORT=5000
NODE_ENV=development

# MongoDB - use MongoDB Atlas or local
MONGO_URI=mongodb://localhost:27017/kt_portfolio
# OR Atlas: MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/kt_portfolio

# Admin password (for the admin panel login)
ADMIN_PASSWORD=your_secure_password_here

# CORS - frontend URL
CLIENT_URL=http://localhost:5173

# Optional: Supabase (if using instead of MongoDB)
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_ANON_KEY=your_anon_key_here
